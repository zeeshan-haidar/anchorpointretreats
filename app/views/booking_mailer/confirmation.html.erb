<%# app/views/booking_mailer/confirmation.html.erb %>
<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <style>
    body { font-family: 'Inter Tight', Helvetica, Arial, sans-serif; color: #312B24; line-height: 1.6; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 0 auto; padding: 40px 20px; }
    .header { text-align: center; padding: 30px 0; background-color: #64734F; }
    .header h1 { color: #FFFFFF; font-family: Lora, serif; font-size: 28px; margin: 0; }
    .content { padding: 30px; background-color: #FFFFFF; }
    .card { background-color: #EAF0EA; padding: 20px; border-radius: 0; margin: 20px 0; }
    .card h3 { font-family: Lora, serif; color: #312B24; margin: 0 0 15px 0; }
    .detail-row { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .detail-label { color: #747474; font-weight: 400; }
    .detail-value { font-weight: 600; }
    .confirmation-number { font-size: 24px; font-weight: 700; color: #64734F; text-align: center; margin: 20px 0; }
    .badge { display: inline-block; padding: 6px 16px; background-color: #64734F; color: #FFFFFF; font-size: 14px; }
    .footer { text-align: center; padding: 20px; color: #747474; font-size: 13px; }
    hr { border: none; border-top: 1px solid #D6D1CC; margin: 20px 0; }
    .button { display: inline-block; padding: 14px 28px; background-color: #64734F; color: #FFFFFF; text-decoration: none; font-family: Lora, serif; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Booking Confirmed</h1>
    </div>

    <div class="content">
      <p>Dear <strong><%= @booking.guest_name %></strong>,</p>
      <p>Thank you for booking your stay at <strong>The Anchorpoint Retreat</strong>. Your reservation is confirmed and we're excited to host you!</p>

      <div class="confirmation-number">
        <%= @booking.confirmation_number %>
      </div>

      <div class="card">
        <h3>Stay Details</h3>
        <div class="detail-row">
          <span class="detail-label">Property</span>
          <span class="detail-value"><%= @property.name %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Check-in</span>
          <span class="detail-value"><%= @booking.check_in.strftime("%A, %B %d, %Y") %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Check-out</span>
          <span class="detail-value"><%= @booking.check_out.strftime("%A, %B %d, %Y") %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Nights</span>
          <span class="detail-value"><%= @booking.num_nights %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Guests</span>
          <span class="detail-value"><%= @booking.num_guests %></span>
        </div>
      </div>

      <div class="card">
        <h3>Payment Summary</h3>
        <div class="detail-row">
          <span class="detail-label">Amount Paid</span>
          <span class="detail-value"><%= @amount_paid %></span>
        </div>
        <% if @balance_due %>
          <div class="detail-row">
            <span class="detail-label">Balance Due</span>
            <span class="detail-value"><%= @balance_due %></span>
          </div>
          <p style="color: #747474; font-size: 14px; margin-top: 12px;">
            Your remaining balance will be due before check-in. We'll send you a reminder.
          </p>
        <% end %>
      </div>

      <div class="card">
        <h3>Getting There</h3>
        <p><strong>Address:</strong> <%= @property.address %>, <%= @property.city %>, <%= @property.state %> <%= @property.zip %></p>
        <p><strong>Check-in:</strong> <%= @property.check_in_time %></p>
        <p><strong>Check-out:</strong> <%= @property.check_out_time %></p>
      </div>

      <p style="margin-top: 24px;">
        If you have any questions before your stay, don't hesitate to reach out. We're here to help make your retreat unforgettable.
      </p>

      <p>Warm regards,<br>The Anchorpoint Retreat Team</p>

      <hr>
      <p style="color: #747474; font-size: 13px;">
        This email was sent to <%= @booking.guest_email %>. If you have any questions, please reply to this email.
      </p>
    </div>

    <div class="footer">
      <p>&copy; <%= Date.current.year %> The Anchorpoint Retreat. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
