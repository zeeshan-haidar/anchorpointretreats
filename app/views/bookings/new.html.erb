<%# app/views/bookings/new.html.erb %>
<% content_for :title, "Book Your Stay — The Anchorpoint Retreat" %>
<% content_for :description, "Complete your booking for The Anchorpoint Retreat in Alma, Colorado." %>

<section class="section">
  <div class="hero-container">
    <div class="text-center mb-5">
      <span class="sub-heading">Booking</span>
      <h1>Complete Your Booking</h1>
      <p class="lead">Tell us about yourself and confirm your stay.</p>
    </div>

    <div class="row g-5">
      <%# Booking Form %>
      <div class="col-lg-7">
        <%= form_with model: @booking, url: book_path, local: true, class: "needs-validation", data: { controller: "booking-form" } do |f| %>
          <%= hidden_field_tag :check_in, @check_in %>
          <%= hidden_field_tag :check_out, @check_out %>
          <%= hidden_field_tag :num_guests, @num_guests %>

          <% if flash[:alert] %>
            <div class="alert alert-danger"><%= flash[:alert] %></div>
          <% end %>

          <div class="mb-3">
            <%= f.label :guest_name, "Full Name *", class: "form-label" %>
            <%= f.text_field :guest_name, class: "form-control", required: true, placeholder: "Your full name" %>
            <% if @booking&.errors&.include?(:guest_name) %>
              <div class="text-danger small"><%= @booking.errors.full_messages_for(:guest_name).join(", ") %></div>
            <% end %>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <%= f.label :guest_email, "Email *", class: "form-label" %>
              <%= f.email_field :guest_email, class: "form-control", required: true, placeholder: "you@example.com" %>
              <% if @booking&.errors&.include?(:guest_email) %>
                <div class="text-danger small"><%= @booking.errors.full_messages_for(:guest_email).join(", ") %></div>
              <% end %>
            </div>
            <div class="col-md-6">
              <%= f.label :guest_phone, "Phone *", class: "form-label" %>
              <%= f.telephone_field :guest_phone, class: "form-control", required: true, placeholder: "(555) 123-4567" %>
              <% if @booking&.errors&.include?(:guest_phone) %>
                <div class="text-danger small"><%= @booking.errors.full_messages_for(:guest_phone).join(", ") %></div>
              <% end %>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <%= f.label :company_name, "Company Name", class: "form-label" %>
              <%= f.text_field :company_name, class: "form-control", placeholder: "Optional" %>
            </div>
            <div class="col-md-6">
              <%= f.label :retreat_type, "Retreat Type", class: "form-label" %>
              <%= f.select :retreat_type,
                  [["Select type...", ""], ["Founder Retreat & Executive Reset", "founder"],
                   ["Remote Work & Creative Escape", "remote_work"],
                   ["Couples & Small Group Getaway", "couples"],
                   ["Wellness Retreat", "wellness"],
                   ["Family Trip", "family"], ["Other", "other"]],
                  {}, { class: "form-select" } %>
            </div>
          </div>

          <div class="mb-4">
            <%= f.label :special_requests, "Special Requests", class: "form-label" %>
            <%= f.text_area :special_requests, class: "form-control", rows: 4, placeholder: "Any special requests or accommodations we should know about?" %>
          </div>

          <div class="d-grid">
            <%= f.submit "Proceed to Payment", class: "btn btn-accent btn-lg" %>
          </div>
          <div class="text-center mt-3">
            <a href="/availability?check_in=<%= @check_in&.strftime("%Y-%m-%d") %>&check_out=<%= @check_out&.strftime("%Y-%m-%d") %>&num_guests=<%= @num_guests %>" class="btn btn-outline-accent btn-sm">
              <i class="fa-solid fa-arrow-left"></i> Go Back to Availability
            </a>
          </div>
        <% end %>
      </div>

      <%# Pricing Summary Sidebar %>
      <div class="col-lg-5">
        <div class="card p-4" style="background: var(--bg-2); border: none; position: sticky; top: 120px;">
          <h3 class="heading-sm mb-4">Your Stay</h3>

          <div class="d-flex justify-content-between mb-2">
            <span>Check-in</span>
            <span class="fw-bold"><%= @check_in&.strftime("%b %d, %Y") %></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span>Check-out</span>
            <span class="fw-bold"><%= @check_out&.strftime("%b %d, %Y") %></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span>Guests</span>
            <span class="fw-bold"><%= @num_guests %></span>
          </div>

          <hr>

          <% if @pricing&.success? %>
            <div class="d-flex justify-content-between mb-2">
              <span>Nightly Rate</span>
              <span><%= number_to_currency(@pricing.nightly_rate_cents / 100.0) %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Number of Nights</span>
              <span><%= @pricing.num_nights %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Subtotal</span>
              <span><%= number_to_currency(@pricing.subtotal_cents / 100.0) %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Cleaning Fee</span>
              <span><%= number_to_currency(@pricing.cleaning_fee_cents / 100.0) %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Taxes (8.5%)</span>
              <span><%= number_to_currency(@pricing.taxes_cents / 100.0) %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between mb-2 fw-bold fs-5">
              <span>Total</span>
              <span><%= number_to_currency(@pricing.total_cents / 100.0) %></span>
            </div>
            <div class="d-flex justify-content-between text-muted small">
              <span>Deposit due now (25%)</span>
              <span><%= number_to_currency(@pricing.deposit_amount_cents / 100.0) %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
