<%# app/views/bookings/payment.html.erb %>
<% content_for :title, "Payment — The Anchorpoint Retreat" %>

<section class="section">
  <div class="hero-container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="text-center mb-5">
          <span class="sub-heading">Payment</span>
          <h1>Choose Your Payment Option</h1>
          <p class="lead">Secure your reservation with a deposit or pay in full.</p>
        </div>

        <div class="card p-4 mb-4" style="background: var(--bg-2); border: none;">
          <h3 class="heading-sm mb-3">Booking Summary</h3>
          <div class="row g-3">
            <div class="col-md-6">
              <p><strong>Confirmation:</strong> <%= @booking.confirmation_number %></p>
              <p><strong>Check-in:</strong> <%= @booking.check_in.strftime("%b %d, %Y") %></p>
              <p><strong>Check-out:</strong> <%= @booking.check_out.strftime("%b %d, %Y") %></p>
              <p><strong>Guests:</strong> <%= @booking.num_guests %></p>
            </div>
            <div class="col-md-6">
              <p><strong>Total:</strong> <%= number_to_currency(@booking.total_cents / 100.0) %></p>
              <p><strong>Deposit (25%):</strong> <%= number_to_currency(@booking.deposit_amount_cents / 100.0) %></p>
              <p><strong>Balance after deposit:</strong> <%= number_to_currency((@booking.total_cents - @booking.deposit_amount_cents) / 100.0) %></p>
            </div>
          </div>
        </div>

        <div class="text-center mb-4">
          <a href="/availability?check_in=<%= @booking.check_in.strftime('%Y-%m-%d') %>&check_out=<%= @booking.check_out.strftime('%Y-%m-%d') %>&num_guests=<%= @booking.num_guests %>" class="btn btn-outline-accent btn-sm">
            <i class="fa-solid fa-arrow-left"></i> Change Dates
          </a>
        </div>

        <div class="row g-4">
          <%# Deposit Option %>
          <div class="col-md-6">
            <div class="card p-4 text-center h-100" style="border: 2px solid var(--accent-color);">
              <i class="fa-solid fa-shield-halved fa-3x accent-color mb-3"></i>
              <h3>Pay Deposit</h3>
              <p class="display-6 fw-bold accent-color mb-2"><%= number_to_currency(@booking.deposit_amount_cents / 100.0) %></p>
              <p class="text-muted">25% of total due now. Remaining balance will be collected later.</p>
              <%= form_tag booking_checkout_path(@booking), method: :post do %>
                <%= hidden_field_tag :payment_type, "deposit" %>
                <%= submit_tag "Pay Deposit", class: "btn btn-accent w-100" %>
              <% end %>
            </div>
          </div>

          <%# Full Payment Option %>
          <div class="col-md-6">
            <div class="card p-4 text-center h-100" style="border: 2px solid var(--accent-color);">
              <i class="fa-solid fa-check-circle fa-3x accent-color mb-3"></i>
              <h3>Pay Full Amount</h3>
              <p class="display-6 fw-bold mb-2"><%= number_to_currency(@booking.total_cents / 100.0) %></p>
              <p class="text-muted">Pay the full amount now and enjoy peace of mind.</p>
              <%= form_tag booking_checkout_path(@booking), method: :post do %>
                <%= hidden_field_tag :payment_type, "full" %>
                <%= submit_tag "Pay Full Amount", class: "btn btn-accent w-100" %>
              <% end %>
            </div>
          </div>
        </div>

        <div class="text-center mt-4">
          <p class="text-muted small">
            <i class="fa-solid fa-lock"></i> Secure payment processed by Stripe.
            Your payment information is encrypted and never stored on our servers.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
