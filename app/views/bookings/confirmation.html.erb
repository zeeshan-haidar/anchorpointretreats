<%# app/views/bookings/confirmation.html.erb %>
<% content_for :title, "Booking Confirmed — The Anchorpoint Retreat" %>

<section class="section">
  <div class="hero-container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">

        <div class="mb-5">
          <% if @booking.refunded? %>
            <i class="fa-solid fa-rotate-left fa-5x" style="color: #747474;"></i>
            <h1 class="mt-4">Booking Refunded</h1>
            <p class="lead">This booking has been refunded. Please refer to your refund confirmation email for details.</p>
          <% elsif @booking.fully_paid? || @booking.confirmed? %>
            <i class="fa-solid fa-check-circle fa-5x" style="color: #64734F;"></i>
            <h1 class="mt-4">Booking Confirmed!</h1>
            <p class="lead">Thank you for booking your stay at The Anchorpoint Retreat. We're excited to host you!</p>
          <% elsif @booking.cancelled? %>
            <i class="fa-solid fa-ban fa-5x" style="color: #dc3545;"></i>
            <h1 class="mt-4">Booking Cancelled</h1>
            <p class="lead">This booking has been cancelled. If you have any questions, please contact us.</p>
          <% else %>
            <i class="fa-solid fa-check-circle fa-5x" style="color: #64734F;"></i>
            <h1 class="mt-4">Booking Details</h1>
            <p class="lead">Your booking has been created. Please complete payment to confirm.</p>
          <% end %>
        </div>

        <div class="card p-4 mb-4 text-start" style="background: var(--bg-2); border: none;">
          <h3 class="heading-sm mb-3">Confirmation Details</h3>
          <div class="row g-3">
            <div class="col-md-6">
              <p><strong>Confirmation #:</strong></p>
              <p class="fs-4 fw-bold" style="color: var(--accent-color);"><%= @booking.confirmation_number %></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Guest Name:</strong> <span><%= @booking.guest_name %></span></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Email:</strong> <span><%= @booking.guest_email %></span></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Check-in:</strong> <span><%= @booking.check_in.strftime("%A, %B %d, %Y") %></span></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Check-out:</strong> <span><%= @booking.check_out.strftime("%A, %B %d, %Y") %></span></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Guests:</strong> <span><%= @booking.num_guests %></span></p>
            </div>
            <div class="col-md-6">
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Number of Nights:</strong> <span><%= @booking.num_nights %></span></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Total:</strong> <span class="fw-bold" style="color: var(--accent-color);"><%= number_to_currency(@booking.total_cents / 100.0) %></span></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Amount Paid:</strong> <span><%= number_to_currency(@booking.amount_paid_cents / 100.0) %></span></p>
              <p style="display: flex; gap: 8px;"><strong style="white-space: nowrap;">Status:</strong>
                <% status_badge_class = case @booking.status
                  when "refunded" then "bg-secondary"
                  when "cancelled" then "bg-danger"
                  when "pending" then "bg-warning text-dark"
                  else "bg-success"
                end %>
                <span class="badge <%= status_badge_class %>"><%= @booking.status.titleize %></span>
              </p>
            </div>
          </div>
        </div>

        <% if @booking.refunded? %>
          <div class="mt-4">
            <h3 class="heading-sm mb-3">Refund Information</h3>
            <p>Your refund has been processed. Depending on your payment method, it may take 5–10 business days to appear on your statement.</p>
            <p class="text-muted small">If you have any questions about your refund, please don't hesitate to reach out.</p>
          </div>

          <div class="d-flex flex-wrap gap-3 justify-content-center mt-4">
            <a href="/" class="btn btn-outline-accent">Return to Home</a>
            <a href="/policies" class="btn btn-outline-accent">View Policies</a>
          </div>
        <% elsif @booking.fully_paid? || @booking.confirmed? %>
          <div class="mt-4">
            <h3 class="heading-sm mb-3">What's Next?</h3>
            <p>A confirmation email has been sent to <strong><%= @booking.guest_email %></strong> with all the details of your stay.</p>
            <p>Check-in time: <strong>3:00 PM</strong> | Check-out time: <strong>11:00 AM</strong></p>
            <p class="text-muted small">If you have any questions before your stay, don't hesitate to reach out.</p>
          </div>

          <div class="d-flex flex-wrap gap-3 justify-content-center mt-4">
            <a href="/" class="btn btn-outline-accent">Return to Home</a>
            <a href="/the-retreat" class="btn btn-outline-accent">View Property Details</a>
          </div>
        <% elsif @booking.cancelled? %>
          <div class="mt-4">
            <h3 class="heading-sm mb-3">Cancellation Details</h3>
            <p>If you believe this was a mistake or have any questions, please contact us.</p>
          </div>

          <div class="d-flex flex-wrap gap-3 justify-content-center mt-4">
            <a href="/" class="btn btn-outline-accent">Return to Home</a>
            <a href="/policies" class="btn btn-outline-accent">View Policies</a>
          </div>
        <% else %>
          <div class="mt-4">
            <a href="<%= booking_payment_path(@booking) %>" class="btn btn-accent btn-lg">Complete Payment</a>
          </div>
        <% end %>

      </div>
    </div>
  </div>
</section>
