<%# app/views/inquiry_mailer/new_inquiry_alert.html.erb %>
<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <style>
    body { font-family: 'Inter Tight', Helvetica, Arial, sans-serif; color: #312B24; line-height: 1.6; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 0 auto; padding: 40px 20px; }
    .header { text-align: center; padding: 30px 0; background-color: #64734F; }
    .header h1 { color: #FFFFFF; font-family: Lora, serif; font-size: 28px; margin: 0; }
    .content { padding: 30px; background-color: #FFFFFF; }
    .card { background-color: #EAF0EA; padding: 20px; margin: 20px 0; }
    .card h3 { font-family: Lora, serif; color: #312B24; margin: 0 0 15px 0; }

    .footer { text-align: center; padding: 20px; color: #747474; font-size: 13px; }
    hr { border: none; border-top: 1px solid #D6D1CC; margin: 20px 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>New Inquiry Received</h1>
    </div>
    <div class="content">
      <p>A new inquiry has been submitted to The Anchorpoint Retreat.</p>

      <div class="card">
        <h3>Guest Information</h3>
        <table style="width: 100%; border-collapse: collapse;">
          <tr>
            <td style="color: #747474; font-weight: 400; padding: 4px 0; vertical-align: top; white-space: nowrap;">Name</td>
            <td style="font-weight: 600; padding: 4px 0; text-align: right; vertical-align: top;"><%= @inquiry.name %></td>
          </tr>
          <tr>
            <td style="color: #747474; font-weight: 400; padding: 4px 0; vertical-align: top; white-space: nowrap;">Email</td>
            <td style="font-weight: 600; padding: 4px 0; text-align: right; vertical-align: top;"><%= @inquiry.email %></td>
          </tr>
          <% if @inquiry.phone.present? %>
            <tr>
              <td style="color: #747474; font-weight: 400; padding: 4px 0; vertical-align: top; white-space: nowrap;">Phone</td>
              <td style="font-weight: 600; padding: 4px 0; text-align: right; vertical-align: top;"><%= @inquiry.phone %></td>
            </tr>
          <% end %>
          <% if @inquiry.company.present? %>
            <tr>
              <td style="color: #747474; font-weight: 400; padding: 4px 0; vertical-align: top; white-space: nowrap;">Company</td>
              <td style="font-weight: 600; padding: 4px 0; text-align: right; vertical-align: top;"><%= @inquiry.company %></td>
            </tr>
          <% end %>
          <% if @inquiry.retreat_type.present? %>
            <tr>
              <td style="color: #747474; font-weight: 400; padding: 4px 0; vertical-align: top; white-space: nowrap;">Retreat Type</td>
              <td style="font-weight: 600; padding: 4px 0; text-align: right; vertical-align: top;"><%= @inquiry.retreat_type.titleize %></td>
            </tr>
          <% end %>
        </table>
      </div>

      <div class="card">
        <h3>Inquiry Details</h3>
        <table style="width: 100%; border-collapse: collapse;">
          <% if @inquiry.preferred_dates.present? %>
            <tr>
              <td style="color: #747474; font-weight: 400; padding: 4px 0; vertical-align: top; white-space: nowrap;">Preferred Dates</td>
              <td style="font-weight: 600; padding: 4px 0; text-align: right; vertical-align: top;"><%= @inquiry.preferred_dates %></td>
            </tr>
          <% end %>
          <% if @inquiry.group_size.present? %>
            <tr>
              <td style="color: #747474; font-weight: 400; padding: 4px 0; vertical-align: top; white-space: nowrap;">Group Size</td>
              <td style="font-weight: 600; padding: 4px 0; text-align: right; vertical-align: top;"><%= @inquiry.group_size %></td>
            </tr>
          <% end %>
        </table>
        <p style="margin-top: 12px;"><strong>Message:</strong></p>
        <p><%= @inquiry.message %></p>
      </div>

      <p style="color: #747474; font-size: 14px;">
        Log in to the admin panel to view and respond to this inquiry.
      </p>

      <hr>
      <p style="color: #747474; font-size: 13px;">
        This is an automated notification. Please respond to the guest within 24-48 hours.
      </p>
    </div>
    <div class="footer">
      <p>&copy; <%= Date.current.year %> The Anchorpoint Retreat. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
