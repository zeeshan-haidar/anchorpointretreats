<%# admin/inquiries/show.html.erb %>
<% content_for :page_title, "Inquiry from #{@inquiry.name}" %>

<div class="row g-3">
  <div class="col-12 col-lg-8">
    <div class="admin-card mb-3">
      <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span>Inquiry Details</span>
        <span class="badge badge-<%= @inquiry.status %>" style="font-size: 0.875rem;"><%= @inquiry.status.humanize %></span>
      </div>
      <div class="admin-card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <div class="small text-muted mb-1">Name</div>
            <div class="fw-medium"><%= @inquiry.name %></div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="small text-muted mb-1">Email</div>
            <div class="fw-medium"><%= mail_to @inquiry.email %></div>
          </div>
          <% if @inquiry.phone.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Phone</div>
              <div class="fw-medium"><%= @inquiry.phone %></div>
            </div>
          <% end %>
          <% if @inquiry.company.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Company</div>
              <div class="fw-medium"><%= @inquiry.company %></div>
            </div>
          <% end %>
          <% if @inquiry.retreat_type.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Retreat Type</div>
              <div class="fw-medium"><%= @inquiry.retreat_type.humanize %></div>
            </div>
          <% end %>
          <% if @inquiry.preferred_dates.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Preferred Dates</div>
              <div class="fw-medium"><%= @inquiry.preferred_dates %></div>
            </div>
          <% end %>
          <% if @inquiry.group_size.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Group Size</div>
              <div class="fw-medium"><%= @inquiry.group_size %></div>
            </div>
          <% end %>
          <div class="col-12 mb-3">
            <div class="small text-muted mb-1">Submitted</div>
            <div class="fw-medium"><%= @inquiry.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
          </div>
          <div class="col-12">
            <div class="small text-muted mb-1">Message</div>
            <div class="p-3 bg-light rounded" style="white-space: pre-wrap;"><%= @inquiry.message %></div>
          </div>
        </div>
      </div>
    </div>

    <%# Status Update Form %>
    <div class="admin-card">
      <div class="admin-card-header">Update Inquiry</div>
      <div class="admin-card-body">
        <%= form_with model: @inquiry, url: admin_inquiry_path(@inquiry), method: :patch, class: "admin-form" do |f| %>
          <div class="row g-3">
            <div class="col-md-4">
              <%= f.label :status, "Status", class: "form-label" %>
              <%= f.select :status,
                           options_for_select(Inquiry.statuses.map { |k, v| [k.humanize, k] },
                                              @inquiry.status),
                           {}, class: "form-select" %>
            </div>
            <div class="col-md-8">
              <%= f.label :admin_notes, "Admin Notes (internal)", class: "form-label" %>
              <%= f.text_area :admin_notes, rows: 3, class: "form-control", placeholder: "Add internal notes..." %>
            </div>
            <div class="col-12">
              <%= f.submit "Update Inquiry", class: "btn btn-primary admin-btn" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-4">
    <div class="admin-card">
      <div class="admin-card-header">Quick Actions</div>
      <div class="admin-card-body d-flex flex-column gap-2">
        <%= mail_to @inquiry.email,
                    subject: "Re: Your Inquiry - The Anchorpoint Retreat",
                    class: "btn btn-outline-primary admin-btn w-100" do %>
          <i class="fa-solid fa-reply me-1"></i> Reply via Email
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  <%= link_to "← Back to Inquiries", admin_inquiries_path, class: "btn btn-sm btn-outline-secondary" %>
</div>
