<%# admin/testimonials/edit.html.erb %>
<% content_for :page_title, "Edit Testimonial" %>

<div class="row">
  <div class="col-12 col-lg-6">
    <div class="admin-card">
      <div class="admin-card-header">Edit Testimonial</div>
      <div class="admin-card-body">
        <%= form_with model: @testimonial, url: admin_testimonial_path(@testimonial), method: :patch, class: "admin-form" do |f| %>
          <div class="mb-3">
            <%= f.label :author_name, "Author Name", class: "form-label" %>
            <%= f.text_field :author_name, class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= f.label :author_title, "Author Title", class: "form-label" %>
            <%= f.text_field :author_title, class: "form-control" %>
          </div>
          <% if @testimonial.image.attached? %>
            <div class="mb-3">
              <div class="small text-muted mb-1">Current Photo</div>
              <%= image_tag @testimonial.image.variant(:thumb), style: "width: 80px; height: 80px; object-fit: cover; border-radius: 50%;" if @testimonial.image.variable? %>
            </div>
          <% end %>
          <div class="mb-3">
            <%= f.label :image, "Author Photo (leave blank to keep current)", class: "form-label" %>
            <%= f.file_field :image, accept: "image/*", class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= f.label :content, "Testimonial Text", class: "form-label" %>
            <%= f.text_area :content, rows: 4, class: "form-control" %>
          </div>
          <div class="row mb-3">
            <div class="col-md-4">
              <%= f.label :rating, "Rating (1-5)", class: "form-label" %>
              <%= f.number_field :rating, class: "form-control", min: 1, max: 5 %>
            </div>
            <div class="col-md-4">
              <%= f.label :retreat_type, "Retreat Type", class: "form-label" %>
              <%= f.select :retreat_type,
                           options_for_select(["", "Corporate", "Wellness", "Private", "Other"], @testimonial.retreat_type),
                           {}, class: "form-select" %>
            </div>
            <div class="col-md-4 d-flex align-items-end">
              <div class="form-check">
                <%= f.check_box :featured, class: "form-check-input" %>
                <%= f.label :featured, "Featured", class: "form-check-label" %>
              </div>
            </div>
          </div>
          <div>
            <%= f.submit "Update Testimonial", class: "btn btn-primary admin-btn" %>
            <%= link_to "Cancel", admin_testimonials_path, class: "btn btn-outline-secondary admin-btn ms-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
