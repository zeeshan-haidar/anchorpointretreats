<%# admin/photos/index.html.erb %>
<% content_for :page_title, "Property Photos" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <p class="text-muted mb-0 small"><%= @photos.count %> photo(s)</p>
  <%= link_to "Add Photo", new_admin_property_photo_path, class: "btn btn-primary admin-btn btn-sm" %>
</div>

<% if @photos.any? %>
  <div class="row g-3" id="photoGrid" data-controller="photo-sort">
    <% @photos.each do |photo| %>
      <div class="col-12 col-sm-6 col-md-4 col-lg-3" data-photo-id="<%= photo.id %>">
        <div class="admin-card">
          <% if photo.image.attached? %>
            <div style="height: 180px; overflow: hidden; border-radius: 8px 8px 0 0;">
              <%= image_tag photo.image.variant(:thumb), class: "w-100 h-100", style: "object-fit: cover;" if photo.image.variable? %>
            </div>
          <% else %>
            <div style="height: 180px; background: #f3f4f6; border-radius: 8px 8px 0 0;" class="d-flex align-items-center justify-content-center text-muted">
              <i class="fa-solid fa-image fa-3x"></i>
            </div>
          <% end %>
          <div class="p-2">
            <div class="small">
              <div><%= photo.category.humanize %></div>
              <% if photo.alt_text.present? %>
                <div class="text-muted" style="font-size: 0.7rem;"><%= truncate(photo.alt_text, length: 40) %></div>
              <% end %>
            </div>
            <div class="mt-2 d-flex gap-1">
              <%= button_to "Delete", admin_property_photo_path(photo),
                            method: :delete,
                            data: { confirm: "Delete this photo?" },
                            class: "btn btn-sm btn-outline-danger",
                            style: "border-radius: 4px; font-size: 0.75rem;" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="admin-card">
    <div class="admin-card-body text-center text-muted py-5">
      <i class="fa-solid fa-image fa-3x mb-3"></i>
      <p>No photos uploaded yet.</p>
      <%= link_to "Upload Photo", new_admin_property_photo_path, class: "btn btn-primary admin-btn" %>
    </div>
  </div>
<% end %>
