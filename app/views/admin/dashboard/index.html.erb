<%# admin/dashboard/index.html.erb %>
<% content_for :page_title, "Dashboard" %>

<%# Stat Cards %>
<div class="row g-3 mb-4">
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="d-flex align-items-center gap-3 mb-2">
        <div class="stat-icon" style="background: #dbeafe;">
          <i class="fa-solid fa-dollar-sign" style="color: #1e40af;"></i>
        </div>
        <div>
          <div class="stat-value"><%= number_to_currency(@stats.monthly_revenue_cents / 100.0, precision: 0) %></div>
          <div class="stat-label">Revenue This Month</div>
        </div>
      </div>
      <div class="stat-change <%= @stats.revenue_change >= 0 ? 'positive' : 'negative' %>">
        <i class="fa-solid fa-<%= @stats.revenue_change >= 0 ? 'arrow-up' : 'arrow-down' %>"></i>
        <%= @stats.revenue_change %>% vs last month
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="d-flex align-items-center gap-3 mb-2">
        <div class="stat-icon" style="background: #d1fae5;">
          <i class="fa-solid fa-calendar-check" style="color: #065f46;"></i>
        </div>
        <div>
          <div class="stat-value"><%= @stats.upcoming_count %></div>
          <div class="stat-label">Upcoming Bookings</div>
        </div>
      </div>
      <div class="stat-change <%= @stats.booking_change >= 0 ? 'positive' : 'negative' %>">
        <i class="fa-solid fa-<%= @stats.booking_change >= 0 ? 'arrow-up' : 'arrow-down' %>"></i>
        <%= @stats.booking_change %>% vs last month
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="d-flex align-items-center gap-3 mb-2">
        <div class="stat-icon" style="background: #fef3c7;">
          <i class="fa-solid fa-bed" style="color: #92400e;"></i>
        </div>
        <div>
          <div class="stat-value"><%= @stats.occupancy_rate %>%</div>
          <div class="stat-label">Occupancy This Month</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="d-flex align-items-center gap-3 mb-2">
        <div class="stat-icon" style="background: #fee2e2;">
          <i class="fa-solid fa-envelope" style="color: #991b1b;"></i>
        </div>
        <div>
          <div class="stat-value"><%= @stats.new_inquiries_count %></div>
          <div class="stat-label">New Inquiries</div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <%# Upcoming Bookings %>
  <div class="col-12 col-lg-6">
    <div class="admin-card">
      <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span>Upcoming Bookings</span>
        <%= link_to "View All", admin_bookings_path, class: "btn btn-sm btn-outline-secondary", style: "border-radius: 6px;" %>
      </div>
      <div class="admin-card-body p-0">
        <table class="admin-table mb-0">
          <thead>
            <tr>
              <th>Guest</th>
              <th>Dates</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if @upcoming_bookings.any? %>
              <% @upcoming_bookings.each do |booking| %>
                <tr>
                  <td><%= booking.guest_name %></td>
                  <td><%= booking.check_in.strftime("%b %d") %> – <%= booking.check_out.strftime("%b %d, %Y") %></td>
                  <td><span class="badge badge-<%= booking.status %>"><%= booking.status.humanize %></span></td>
                  <td class="action-links">
                    <%= link_to "View", admin_booking_path(booking) %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center text-muted py-3">No upcoming bookings.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# Recent Inquiries %>
  <div class="col-12 col-lg-6">
    <div class="admin-card">
      <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span>Recent Inquiries</span>
        <%= link_to "View All", admin_inquiries_path, class: "btn btn-sm btn-outline-secondary", style: "border-radius: 6px;" %>
      </div>
      <div class="admin-card-body p-0">
        <table class="admin-table mb-0">
          <thead>
            <tr>
              <th>Name</th>
              <th>Date</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if @recent_inquiries.any? %>
              <% @recent_inquiries.each do |inquiry| %>
                <tr>
                  <td><%= inquiry.name %></td>
                  <td><%= inquiry.created_at.strftime("%b %d, %Y") %></td>
                  <td><span class="badge badge-<%= inquiry.status %>"><%= inquiry.status.humanize %></span></td>
                  <td class="action-links">
                    <%= link_to "View", admin_inquiry_path(inquiry) %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center text-muted py-3">No inquiries yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%# Quick Actions %>
<div class="mt-4">
  <div class="admin-card">
    <div class="admin-card-header">
      Quick Actions
    </div>
    <div class="admin-card-body d-flex flex-wrap gap-2">
      <%= link_to admin_calendar_index_path, class: "btn btn-outline-secondary admin-btn" do %>
        <i class="fa-solid fa-calendar-days me-1"></i> Manage Calendar
      <% end %>
      <%= link_to edit_admin_property_path, class: "btn btn-outline-secondary admin-btn" do %>
        <i class="fa-solid fa-pen-to-square me-1"></i> Edit Property
      <% end %>
      <%= link_to export_admin_bookings_path, class: "btn btn-outline-secondary admin-btn", data: { turbo: false } do %>
        <i class="fa-solid fa-download me-1"></i> Export Bookings CSV
      <% end %>
    </div>
  </div>
</div>
