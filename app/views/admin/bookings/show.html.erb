<%# admin/bookings/show.html.erb %>
<% content_for :page_title, "Booking ##{@booking.confirmation_number}" %>

<div class="row g-3">
  <%# Guest Info %>
  <div class="col-12 col-lg-8">
    <div class="admin-card mb-3">
      <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span>Booking Details</span>
        <span class="badge badge-<%= @booking.status %>" style="font-size: 0.875rem;"><%= @booking.status.humanize %></span>
      </div>
      <div class="admin-card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <div class="small text-muted mb-1">Confirmation Number</div>
            <div class="fw-medium"><%= @booking.confirmation_number %></div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="small text-muted mb-1">Created</div>
            <div class="fw-medium"><%= @booking.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="small text-muted mb-1">Guest Name</div>
            <div class="fw-medium"><%= @booking.guest_name %></div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="small text-muted mb-1">Guest Email</div>
            <div class="fw-medium"><%= mail_to @booking.guest_email %></div>
          </div>
          <% if @booking.guest_phone.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Guest Phone</div>
              <div class="fw-medium"><%= @booking.guest_phone %></div>
            </div>
          <% end %>
          <% if @booking.company_name.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Company</div>
              <div class="fw-medium"><%= @booking.company_name %></div>
            </div>
          <% end %>
          <% if @booking.retreat_type.present? %>
            <div class="col-md-6 mb-3">
              <div class="small text-muted mb-1">Retreat Type</div>
              <div class="fw-medium"><%= @booking.retreat_type.humanize %></div>
            </div>
          <% end %>
          <div class="col-12 mb-3">
            <div class="small text-muted mb-1">Stay Dates</div>
            <div class="fw-medium">
              <%= @booking.check_in.strftime("%B %d, %Y") %> –
              <%= @booking.check_out.strftime("%B %d, %Y") %>
              <span class="text-muted">(<%= @booking.num_nights %> nights)</span>
            </div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="small text-muted mb-1">Number of Guests</div>
            <div class="fw-medium"><%= @booking.num_guests %></div>
          </div>
          <% if @booking.special_requests.present? %>
            <div class="col-12 mb-3">
              <div class="small text-muted mb-1">Special Requests</div>
              <div class="fw-medium"><%= simple_format @booking.special_requests %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Pricing %>
    <div class="admin-card mb-3">
      <div class="admin-card-header">Payment & Pricing</div>
      <div class="admin-card-body">
        <div class="row">
          <div class="col-6 col-md-3 mb-2">
            <div class="small text-muted">Nightly Rate</div>
            <div class="fw-medium"><%= number_to_currency(@booking.nightly_rate_cents / 100.0) %></div>
          </div>
          <div class="col-6 col-md-3 mb-2">
            <div class="small text-muted">Subtotal</div>
            <div class="fw-medium"><%= number_to_currency(@booking.subtotal_cents / 100.0) %></div>
          </div>
          <div class="col-6 col-md-3 mb-2">
            <div class="small text-muted">Cleaning Fee</div>
            <div class="fw-medium"><%= number_to_currency(@booking.cleaning_fee_cents / 100.0) %></div>
          </div>
          <div class="col-6 col-md-3 mb-2">
            <div class="small text-muted">Taxes</div>
            <div class="fw-medium"><%= number_to_currency(@booking.taxes_cents / 100.0) %></div>
          </div>
          <div class="col-6 col-md-3 mb-2">
            <div class="small text-muted">Total</div>
            <div class="fw-medium" style="color: #312B24;"><%= number_to_currency(@booking.total_cents / 100.0) %></div>
          </div>
          <div class="col-6 col-md-3 mb-2">
            <div class="small text-muted">Amount Paid</div>
            <div class="fw-medium" style="color: #059669;"><%= number_to_currency(@booking.amount_paid_cents / 100.0) %></div>
          </div>
          <% if @booking.stripe_payment_intent_id.present? %>
            <div class="col-12 mt-2">
              <div class="small text-muted">Stripe Payment Intent</div>
              <div class="fw-medium"><code><%= @booking.stripe_payment_intent_id %></code></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Status Update Form %>
    <div class="admin-card mb-3">
      <div class="admin-card-header">Update Booking</div>
      <div class="admin-card-body">
        <%= form_with model: @booking, url: admin_booking_path(@booking), method: :patch, class: "admin-form" do |f| %>
          <div class="row g-3">
            <div class="col-md-4">
              <%= f.label :status, "Status", class: "form-label" %>
              <%= f.select :status,
                           options_for_select(Booking.active_statuses.map { |k, v| [k.humanize, k] },
                                              @booking.status),
                           {}, class: "form-select" %>
            </div>
            <div class="col-md-8">
              <%= f.label :admin_notes, "Admin Notes (internal)", class: "form-label" %>
              <%= f.text_area :admin_notes, rows: 2, class: "form-control", placeholder: "Add internal notes..." %>
            </div>
            <div class="col-12">
              <%= f.submit "Update Booking", class: "btn btn-primary admin-btn" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Sidebar Actions %>
  <div class="col-12 col-lg-4">
    <%# Actions %>
    <div class="admin-card mb-3">
      <div class="admin-card-header">Actions</div>
      <div class="admin-card-body d-flex flex-column gap-2">
        <% if @booking.amount_paid_cents > 0 && !@booking.refunded? %>
          <div data-controller="refund-confirm"
               data-refund-confirm-amount-value="<%= number_to_currency(@booking.amount_paid_cents / 100.0) %>"
               data-refund-confirm-url-value="<%= refund_admin_booking_path(@booking) %>">
            <%= button_to "Process Refund",
                          refund_admin_booking_path(@booking),
                          method: :post,
                          class: "btn btn-danger admin-btn w-100",
                          data: { turbo: false, action: "refund-confirm#show" } %>

            <%# Refund Confirmation Modal %>
            <div class="modal fade" data-refund-confirm-target="modal" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius: 8px;">
                  <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" style="color: #dc2626;">
                      <i class="fa-solid fa-triangle-exclamation me-2"></i>Confirm Refund
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body">
                    <div class="mb-3">
                      <p class="mb-1">You are about to refund <strong data-refund-confirm-target="amount" style="color: #dc2626;"><%= number_to_currency(@booking.amount_paid_cents / 100.0) %></strong> to the guest.</p>
                      <p class="text-muted small mb-0">This will:</p>
                      <ul class="text-muted small mb-0 mt-1 ps-3">
                        <li>Process a full refund via Stripe</li>
                        <li>Cancel the booking and release availability</li>
                        <li>Send a refund confirmation email to the guest</li>
                      </ul>
                      <p class="fw-bold mt-2 mb-0" style="color: #dc2626;">This action cannot be undone.</p>
                    </div>
                    <div class="mb-3">
                      <label for="refundConfirmInput" class="form-label small fw-medium">
                        Type <code style="background: #fef3c7; padding: 2px 6px; border-radius: 4px; font-size: 0.875rem;">REFUND</code> to confirm:
                      </label>
                      <input type="text"
                             id="refundConfirmInput"
                             data-refund-confirm-target="confirmationInput"
                             data-action="input->refund-confirm#checkConfirmation"
                             class="form-control form-control-sm"
                             placeholder="Type REFUND to confirm"
                             autocomplete="off"
                             style="text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">
                    </div>
                  </div>
                  <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary admin-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="button"
                            class="btn btn-sm btn-danger admin-btn"
                            data-refund-confirm-target="submitBtn"
                            data-action="refund-confirm#confirm"
                            disabled>
                      <i class="fa-solid fa-rotate-left me-1"></i>Process Refund
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Booking Info %>
    <div class="admin-card mb-3">
      <div class="admin-card-header">Booking Info</div>
      <div class="admin-card-body">
        <div class="small mb-2">
          <span class="text-muted">Property:</span><br>
          <span class="fw-medium"><%= @booking.property&.name || "N/A" %></span>
        </div>
        <div class="small">
          <span class="text-muted">Stripe Session:</span><br>
          <span class="fw-medium"><%= @booking.stripe_checkout_session_id || "Not initiated" %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  <%= link_to "← Back to Bookings", admin_bookings_path, class: "btn btn-sm btn-outline-secondary" %>
</div>
