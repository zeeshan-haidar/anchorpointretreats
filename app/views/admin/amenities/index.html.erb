<%# admin/amenities/index.html.erb %>
<% content_for :page_title, "Amenities" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <p class="text-muted mb-0 small"><%= @amenities.count %> amenitie(s)</p>
  <%= link_to "Add Amenity", new_admin_property_amenity_path, class: "btn btn-primary admin-btn btn-sm" %>
</div>

<div class="admin-card">
  <div class="admin-card-body p-0">
    <table class="admin-table mb-0">
      <thead>
        <tr>
          <th>Icon</th>
          <th>Name</th>
          <th>Category</th>
          <th>Featured</th>
          <th>Sort Order</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if @amenities.any? %>
          <% @amenities.each do |amenity| %>
            <tr>
              <td><i class="<%= amenity.icon %>"></i></td>
              <td class="fw-medium"><%= amenity.name %></td>
              <td><span class="badge bg-light text-dark"><%= amenity.category.humanize %></span></td>
              <td>
                <% if amenity.featured? %>
                  <span class="badge badge-completed">Featured</span>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td><%= amenity.sort_order %></td>
              <td class="action-links">
                <%= link_to "Edit", edit_admin_property_amenity_path(amenity) %>
                <%= button_to "Delete", admin_property_amenity_path(amenity),
                              method: :delete,
                              data: { confirm: "Delete this amenity?" },
                              class: "btn btn-sm btn-link text-danger p-0 border-0" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="text-center text-muted py-4">No amenities yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
