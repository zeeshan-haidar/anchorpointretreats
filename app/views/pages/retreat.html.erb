<%# app/views/pages/retreat.html.erb %>
<% content_for :title, "The Retreat — The Anchorpoint Retreat" %>
<% content_for :description, "Explore our Colorado mountain retreat property with 6 bedrooms, 5 bathrooms, gourmet kitchen, hot tub, and panoramic mountain views." %>

<section class="section banner-home" style="background-image: url('<%= asset_path('home/backg1-1920-900.jpg') %>'); min-height: 50vh;">
    <div class="hero-container">
        <div class="banner-home-container text-center">
            <h1 class="banner-home-title">The Anchorpoint Retreat</h1>
            <p class="banner-home-excerpt">Your Private Mountain Sanctuary in Colorado</p>
        </div>
    </div>
</section>

<section class="section">
    <div class="hero-container">
        <div class="row">
            <div class="col-lg-8">
                <span class="sub-heading">The Property</span>
                <h2>A Place to Reconnect</h2>
                <p>Situated on 10+ private acres with sweeping views of the San Juan Mountains, The Anchorpoint Retreat offers an unparalleled escape. The 4,200 square foot lodge combines modern luxury with mountain rustic charm, featuring floor-to-ceiling windows, reclaimed wood accents, and stone fireplaces.</p>
                <p>Whether you're planning a corporate offsite, a wellness retreat, or a family gathering, the property provides the perfect balance of shared spaces for connection and private nooks for quiet reflection.</p>

                <h3 class="mt-4">Property Highlights</h3>
                <ul class="property-highlights">
                    <li><i class="fa-solid fa-check accent-color"></i> 6 bedrooms (sleeps up to 16 guests)</li>
                    <li><i class="fa-solid fa-check accent-color"></i> 5 bathrooms with premium fixtures</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Gourmet kitchen with chef-grade appliances</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Great room with 20-ft ceilings and riverstone fireplace</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Outdoor dining terrace with mountain views</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Private hot tub and sauna</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Fire pit with seating for 16</li>
                    <li><i class="fa-solid fa-check accent-color"></i> 3 miles of private hiking trails</li>
                </ul>

                <h3 class="mt-4">Check-in / Check-out</h3>
                <p>Check-in: 3:00 PM &nbsp;|&nbsp; Check-out: 11:00 AM</p>
            </div>
            <div class="col-lg-4">
                <div class="card p-4">
                    <h3 class="heading-sm">Quick Specs</h3>
                    <table class="specs-table">
                        <tr><td>Bedrooms</td><td>6</td></tr>
                        <tr><td>Bathrooms</td><td>5</td></tr>
                        <tr><td>Max Guests</td><td>16</td></tr>
                        <tr><td>Square Feet</td><td>4,200</td></tr>
                        <tr><td>Acreage</td><td>10+ acres</td></tr>
                        <tr><td>Check-in</td><td>3:00 PM</td></tr>
                        <tr><td>Check-out</td><td>11:00 AM</td></tr>
                    </table>
                    <a href="/availability" class="btn btn-accent w-100 mt-3">Check Availability</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="gallery" class="section-px-pt-small">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading">Gallery</span>
        <h2>Photo Tour</h2>
    </div>
    <div class="hero-container" data-controller="lightbox">
        <%# Tab navigation %>
        <ul class="nav nav-pills justify-content-center mb-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#gallery-all" type="button" role="tab">All</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#gallery-interior" type="button" role="tab">Interior</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#gallery-exterior" type="button" role="tab">Exterior</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#gallery-outdoor" type="button" role="tab">Outdoor &amp; Views</button>
            </li>
        </ul>

        <div class="tab-content">
            <%# All images %>
            <div class="tab-pane fade show active" id="gallery-all" role="tabpanel">
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    <% gallery_all = [
                        { file: "Image-1.jpg", alt: "Mountain view from property" },
                        { file: "Image-2.jpg", alt: "Great room interior" },
                        { file: "Image-3.jpg", alt: "Hot tub under stars" },
                        { file: "Image-4.jpg", alt: "Gourmet kitchen" },
                        { file: "Image-5.jpg", alt: "Bedroom with mountain view" },
                        { file: "Image-6.jpg", alt: "Trail view" },
                        { file: "Image-8.jpg", alt: "Sunset deck view" },
                        { file: "Image-9.jpg", alt: "Dining area" },
                        { file: "Image-10.jpg", alt: "Fireplace and lounge" },
                        { file: "Image-11.jpg", alt: "Outdoor terrace" },
                        { file: "Image-12.jpg", alt: "Bathroom ensuite" },
                        { file: "Image-13.jpg", alt: "Yoga deck" },
                        { file: "Image-14.jpg", alt: "Property exterior" },
                        { file: "Image-15.jpg", alt: "Sitting area" },
                        { file: "Image-16.jpg", alt: "Trail through forest" },
                        { file: "Image-17.jpg", alt: "Property scenic view" },
                        { file: "Image-18.jpg", alt: "Living room seating" },
                        { file: "Image-19.jpg", alt: "Master bedroom" },
                        { file: "Image-20.jpg", alt: "Kitchen detail" },
                        { file: "Image-21.jpg", alt: "Deck seating area" },
                        { file: "Image-22.jpg", alt: "Guest bedroom" },
                        { file: "Image-23.jpg", alt: "Dining table setting" },
                        { file: "Image-24.jpg", alt: "Fire pit area" },
                        { file: "Image-25.jpg", alt: "Reading nook" },
                        { file: "Image-26.jpg", alt: "Staircase detail" },
                        { file: "Image-28.jpg", alt: "Mountain sunrise" },
                        { file: "Image-29.jpg", alt: "Outdoor dining" },
                        { file: "Image-30.jpg", alt: "Entryway" }

                    ] %>
                    <% gallery_all.each do |img| %>
                    <div class="col">
                        <div class="image-container gallery-grid-item">
                            <a href="#" data-turbo="false" data-action="click->lightbox#open" data-lightbox-target="image">
                                <%= image_tag "home/gallery/#{img[:file]}", alt: img[:alt], class: "img-fluid" %>
                            </a>
                        </div>
                    </div>
                    <% end %>
                </div>
            </div>

            <%# Interior %>
            <div class="tab-pane fade" id="gallery-interior" role="tabpanel">
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    <% gallery_interior = [
                        { file: "Image.jpg", alt: "Living room seating" },
                        { file: "Image-1.jpg", alt: "Living room seating" },
                        { file: "Image-2.jpg", alt: "Living room seating" },
                        { file: "Image-3.jpg", alt: "Living room seating" },
                        { file: "Image-4.jpg", alt: "Living room seating" },
                        { file: "Image-5.jpg", alt: "Master bedroom" },
                        { file: "Image-6.jpg", alt: "Bathroom ensuite" },
                        { file: "Image-8.jpg", alt: "Deck seating area" },
                        { file: "Image-9.jpg", alt: "Yoga deck" },
                        { file: "Image-10.jpg", alt: "Guest bedroom" },
                        { file: "Image-11.jpg", alt: "Dining area" },
                        { file: "Image-12.jpg", alt: "Dining table setting" },
                        { file: "Image-13.jpg", alt: "Bedroom with mountain view" },
                        { file: "Image-14.jpg", alt: "Sitting area" },
                        { file: "Image-15.jpg", alt: "Fire pit area" },
                        { file: "Image-16.jpg", alt: "Great room interior" },

                    ] %>
                    <% gallery_interior.each do |img| %>
                    <div class="col">
                        <div class="image-container gallery-grid-item">
                            <a href="#" data-turbo="false" data-action="click->lightbox#open" data-lightbox-target="image">
                                <%= image_tag "home/gallery/#{img[:file]}", alt: img[:alt], class: "img-fluid" %>
                            </a>
                        </div>
                    </div>
                    <% end %>
                </div>
            </div>

            <%# Exterior %>
            <div class="tab-pane fade" id="gallery-exterior" role="tabpanel">
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    <% gallery_exterior = [
                      { file: "Image-17.jpg", alt: "Gourmet kitchen" },
                      { file: "Image-18.jpg", alt: "Gourmet kitchen" },
                      { file: "Image-19.jpg", alt: "Hot tub under stars" },
                      { file: "Image-20.jpg", alt: "Sunset deck view" },
                      { file: "Image-21.jpg", alt: "Reading nook" },
                      { file: "Image-22.jpg", alt: "Fireplace and lounge" }
                    ] %>
                    <% gallery_exterior.each do |img| %>
                    <div class="col">
                        <div class="image-container gallery-grid-item">
                            <a href="#" data-turbo="false" data-action="click->lightbox#open" data-lightbox-target="image">
                                <%= image_tag "home/gallery/#{img[:file]}", alt: img[:alt], class: "img-fluid" %>
                            </a>
                        </div>
                    </div>
                    <% end %>
                </div>
            </div>

            <%# Outdoor & Views %>
            <div class="tab-pane fade" id="gallery-outdoor" role="tabpanel">
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    <% gallery_outdoor = [
                       { file: "Image-23.jpg", alt: "Staircase detail" },
                       { file: "Image-24.jpg", alt: "Mountain sunrise" },
                       { file: "Image-25.jpg", alt: "Mountain sunrise" },
                       { file: "Image-26.jpg", alt: "Entryway" },
                       { file: "Image-28.jpg", alt: "Trail view" },
                       { file: "Image-29.jpg", alt: "Evening view" },
                       { file: "Image-30.jpg", alt: "Evening view" }
                    ] %>
                    <% gallery_outdoor.each do |img| %>
                    <div class="col">
                        <div class="image-container gallery-grid-item">
                            <a href="#" data-turbo="false" data-action="click->lightbox#open" data-lightbox-target="image">
                                <%= image_tag "home/gallery/#{img[:file]}", alt: img[:alt], class: "img-fluid" %>
                            </a>
                        </div>
                    </div>
                    <% end %>
                </div>
            </div>
        </div>

        <%# Gallery Modal %>
        <div class="modal fade" id="galleryModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-xl">
                <div class="modal-content" style="background: transparent; border: none;">
                    <div class="modal-body p-0 text-center">
                        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close" style="z-index: 10; font-size: 1.5rem;"></button>
                        <%= image_tag "", class: "img-fluid", data: { lightbox_target: "modalImg" }, style: "max-height: 90vh; margin: 0 auto;" %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="amenities" class="section">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading">Amenities</span>
        <h2>Every Comfort, Every Detail</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-1 row-cols-md-3 grid-gap-2">
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-spa accent-color"></i> Wellness</h3>
                <ul>
                    <li>Private hot tub</li>
                    <li>Sauna</li>
                    <li>Yoga deck</li>
                    <li>Meditation garden</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-tree accent-color"></i> Outdoor</h3>
                <ul>
                    <li>Fire pit</li>
                    <li>Hiking trails</li>
                    <li>Outdoor dining terrace</li>
                    <li>Mountain views</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-kitchen-set accent-color"></i> Kitchen</h3>
                <ul>
                    <li>Chef-grade appliances</li>
                    <li>Dual ovens</li>
                    <li>Wine refrigerator</li>
                    <li>Espresso machine</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-couch accent-color"></i> Comfort</h3>
                <ul>
                    <li>Riverstone fireplace</li>
                    <li>Radiant floor heating</li>
                    <li>Luxury linens</li>
                    <li>Blackout shades</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-laptop accent-color"></i> Workspace</h3>
                <ul>
                    <li>High-speed WiFi</li>
                    <li>Dedicated meeting room</li>
                    <li>Smart TV / conferencing</li>
                    <li>Printer / scanner</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-shield-halved accent-color"></i> Safety</h3>
                <ul>
                    <li>24/7 security cameras</li>
                    <li>First aid kit</li>
                    <li>Fire extinguishers</li>
                    <li>Emergency generator</li>
                </ul>
            </div>
        </div>
    </div>
</section>
