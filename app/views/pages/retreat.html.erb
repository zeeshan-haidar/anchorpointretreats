                    <% gallery_all.each do |img| %>
                    <div class="col">
                        <div class="image-container gallery-grid-item">
                            <a href="#" data-turbo="false" data-action="click->lightbox#open" data-lightbox-target="image">
                                <%= image_tag "home/gallery/#{img[:file]}", alt: img[:alt], class: "img-fluid" %>
