<%# app/views/pages/retreat.html.erb %>
<% content_for :title, "The Retreat — The Anchorpoint Retreat" %>
<% content_for :description, "Explore our Colorado mountain retreat property with 6 bedrooms, 5 bathrooms, gourmet kitchen, hot tub, and panoramic mountain views." %>

<section class="section banner-home" style="background-image: url('/assets/dummy-img-1920x900.jpg'); min-height: 50vh;">
    <div class="hero-container">
        <div class="banner-home-container text-center">
            <h1 class="banner-home-title">The Anchorpoint Retreat</h1>
            <p class="banner-home-excerpt">Your Private Mountain Sanctuary in Colorado</p>
        </div>
    </div>
</section>

<section class="section">
    <div class="hero-container">
        <div class="row">
            <div class="col-lg-8">
                <span class="sub-heading">The Property</span>
                <h2>A Place to Reconnect</h2>
                <p>Situated on 10+ private acres with sweeping views of the San Juan Mountains, The Anchorpoint Retreat offers an unparalleled escape. The 4,200 square foot lodge combines modern luxury with mountain rustic charm, featuring floor-to-ceiling windows, reclaimed wood accents, and stone fireplaces.</p>
                <p>Whether you're planning a corporate offsite, a wellness retreat, or a family gathering, the property provides the perfect balance of shared spaces for connection and private nooks for quiet reflection.</p>

                <h3 class="mt-4">Property Highlights</h3>
                <ul class="property-highlights">
                    <li><i class="fa-solid fa-check accent-color"></i> 6 bedrooms (sleeps up to 16 guests)</li>
                    <li><i class="fa-solid fa-check accent-color"></i> 5 bathrooms with premium fixtures</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Gourmet kitchen with chef-grade appliances</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Great room with 20-ft ceilings and riverstone fireplace</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Outdoor dining terrace with mountain views</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Private hot tub and sauna</li>
                    <li><i class="fa-solid fa-check accent-color"></i> Fire pit with seating for 16</li>
                    <li><i class="fa-solid fa-check accent-color"></i> 3 miles of private hiking trails</li>
                </ul>

                <h3 class="mt-4">Check-in / Check-out</h3>
                <p>Check-in: 3:00 PM &nbsp;|&nbsp; Check-out: 11:00 AM</p>
            </div>
            <div class="col-lg-4">
                <div class="card p-4">
                    <h3 class="heading-sm">Quick Specs</h3>
                    <table class="specs-table">
                        <tr><td>Bedrooms</td><td>6</td></tr>
                        <tr><td>Bathrooms</td><td>5</td></tr>
                        <tr><td>Max Guests</td><td>16</td></tr>
                        <tr><td>Square Feet</td><td>4,200</td></tr>
                        <tr><td>Acreage</td><td>10+ acres</td></tr>
                        <tr><td>Check-in</td><td>3:00 PM</td></tr>
                        <tr><td>Check-out</td><td>11:00 AM</td></tr>
                    </table>
                    <a href="/availability" class="btn btn-accent w-100 mt-3">Check Availability</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="gallery" class="section-px-pt-small">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading">Gallery</span>
        <h2>Photo Tour</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-1 row-cols-md-3 grid-gap-2">
            <div class="col"><img src="/assets/dummy-img-900x600.jpg" alt="Living room" class="img-fluid"></div>
            <div class="col"><img src="/assets/dummy-img-900x600.jpg" alt="Kitchen" class="img-fluid"></div>
            <div class="col"><img src="/assets/dummy-img-900x600.jpg" alt="Mountain view" class="img-fluid"></div>
            <div class="col"><img src="/assets/dummy-img-600x800.jpg" alt="Bedroom" class="img-fluid"></div>
            <div class="col"><img src="/assets/dummy-img-600x800.jpg" alt="Hot tub" class="img-fluid"></div>
            <div class="col"><img src="/assets/dummy-img-600x400.jpg" alt="Trail" class="img-fluid"></div>
        </div>
    </div>
</section>

<section id="amenities" class="section">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading">Amenities</span>
        <h2>Every Comfort, Every Detail</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-1 row-cols-md-3 grid-gap-2">
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-spa accent-color"></i> Wellness</h3>
                <ul>
                    <li>Private hot tub</li>
                    <li>Sauna</li>
                    <li>Yoga deck</li>
                    <li>Meditation garden</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-tree accent-color"></i> Outdoor</h3>
                <ul>
                    <li>Fire pit</li>
                    <li>Hiking trails</li>
                    <li>Outdoor dining terrace</li>
                    <li>Mountain views</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-kitchen-set accent-color"></i> Kitchen</h3>
                <ul>
                    <li>Chef-grade appliances</li>
                    <li>Dual ovens</li>
                    <li>Wine refrigerator</li>
                    <li>Espresso machine</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-couch accent-color"></i> Comfort</h3>
                <ul>
                    <li>Riverstone fireplace</li>
                    <li>Radiant floor heating</li>
                    <li>Luxury linens</li>
                    <li>Blackout shades</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-laptop accent-color"></i> Workspace</h3>
                <ul>
                    <li>High-speed WiFi</li>
                    <li>Dedicated meeting room</li>
                    <li>Smart TV / conferencing</li>
                    <li>Printer / scanner</li>
                </ul>
            </div>
            <div class="col">
                <h3 class="heading-sm"><i class="fa-solid fa-shield-halved accent-color"></i> Safety</h3>
                <ul>
                    <li>24/7 security cameras</li>
                    <li>First aid kit</li>
                    <li>Fire extinguishers</li>
                    <li>Emergency generator</li>
                </ul>
            </div>
        </div>
    </div>
</section>
