<%# app/views/pages/experience.html.erb %>
<% content_for :title, "Experiences — The Anchorpoint Retreat" %>
<% content_for :description, "Explore corporate retreats, wellness getaways, and private gatherings at The Anchorpoint Retreat in Colorado." %>

<section class="section banner-home" style="background-image: url('/assets/dummy-img-1920x900.jpg'); min-height: 50vh;">
    <div class="hero-container">
        <div class="banner-home-container text-center">
            <h1 class="banner-home-title">Experiences</h1>
            <p class="banner-home-excerpt">Tailored Retreats for Every Purpose</p>
        </div>
    </div>
</section>

<section id="corporate" class="section">
    <div class="hero-container">
        <div class="d-flex flex-column flex-lg-row flex-gap-2 align-items-center">
            <div class="col-lg-6">
                <img src="/assets/dummy-img-900x600.jpg" alt="Corporate Retreat" class="img-fluid">
            </div>
            <div class="col-lg-6">
                <span class="sub-heading">Corporate Retreats</span>
                <h2>Inspire. Connect. Create.</h2>
                <p>Escape the boardroom and unlock your team's potential in the Colorado mountains. Our corporate retreat package includes dedicated meeting spaces, high-speed connectivity, team-building activities, and catered meals — so you can focus on what matters.</p>
                <h3 class="heading-sm mt-3">Sample Activities</h3>
                <ul>
                    <li>Guided team-building workshops</li>
                    <li>Strategy sessions with mountain views</li>
                    <li>Group hiking and outdoor challenges</li>
                    <li>Evening fireside meetings</li>
                    <li>Catered farm-to-table dinners</li>
                </ul>
                <a href="/inquiry" class="btn btn-accent mt-3">Inquire About Corporate Retreats</a>
            </div>
        </div>
    </div>
</section>

<section id="wellness" class="section-px-pt-small banner-service">
    <div class="hero-container">
        <div class="d-flex flex-column flex-lg-row flex-gap-2 align-items-center">
            <div class="col-lg-6">
                <h2 class="accent-color-2">Wellness Retreats</h2>
                <p class="accent-color-2">Nourish your body, mind, and spirit in a setting designed for restoration. Our wellness retreats feature daily yoga and meditation sessions, spa treatments, and farm-to-table cuisine prepared by private chefs.</p>
                <h3 class="heading-sm accent-color-2 mt-3">Sample Activities</h3>
                <ul class="accent-color-2">
                    <li>Sunrise yoga on the deck</li>
                    <li>Guided meditation sessions</li>
                    <li>Private massage and spa treatments</li>
                    <li>Nature walks and forest bathing</li>
                    <li>Nutritional wellness workshops</li>
                </ul>
                <a href="/inquiry" class="btn btn-accent mt-3">Inquire About Wellness Retreats</a>
            </div>
            <div class="col-lg-6">
                <img src="/assets/dummy-img-600x800.jpg" alt="Wellness Retreat" class="img-fluid">
            </div>
        </div>
    </div>
</section>

<section id="private" class="section">
    <div class="hero-container">
        <div class="d-flex flex-column flex-lg-row flex-gap-2 align-items-center">
            <div class="col-lg-6">
                <img src="/assets/dummy-img-600x800.jpg" alt="Private Gathering" class="img-fluid">
            </div>
            <div class="col-lg-6">
                <span class="sub-heading">Private Gatherings</span>
                <h2>Celebrate Life's Moments</h2>
                <p>From milestone birthdays to intimate weddings and family reunions, The Anchorpoint Retreat provides a stunning backdrop for your most cherished gatherings. Our event planning team will handle every detail.</p>
                <h3 class="heading-sm mt-3">Sample Activities</h3>
                <ul>
                    <li>Outdoor ceremony and reception spaces</li>
                    <li>Catered multi-course dinners</li>
                    <li>Bonfire nights with live music</li>
                    <li>Photography tours of the property</li>
                    <li>Custom itinerary planning</li>
                </ul>
                <a href="/inquiry" class="btn btn-accent mt-3">Inquire About Private Gatherings</a>
            </div>
        </div>
    </div>
</section>
