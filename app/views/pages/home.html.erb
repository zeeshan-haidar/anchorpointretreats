<%# app/views/pages/home.html.erb %>
<% content_for :title, "The Anchorpoint Retreat — Modern Alpine Retreat Near Breckenridge" %>
<% content_for :description, "A private mountain chalet in Alma, Colorado created for focused work, quiet resets, small leadership retreats, and year-round mountain adventure." %>

<%# === Section 1: Navigation — handled by shared/_header.html.erb === %>

<%# === Section 2: Hero === %>
<section class="section banner-home" style="padding-bottom: 160px; background-position: center center !important;background-image: url('<%= asset_path('backg-retreat-1920-900.jpg') %>'); min-height: 50vh;">
  <div class="hero-container">
    <div class="banner-home-container">
            <h1 class="banner-home-title animation-box anim-normal anim-delay-sm" data-animation="fade-up">Find Your Anchor in the Colorado Rockies</h1>
            <p class="banner-home-excerpt animation-box anim-slow anim-delay-md" data-animation="fade-up">A private mountain chalet in Alma, Colorado — created for focused work, quiet resets, small leadership retreats, and year-round mountain adventure.</p>
            <div class="d-flex flex-wrap flex-gap-1 justify-content-center">
                <a href="/availability" class="btn btn-accent-2 animation-box anim-normal anim-delay-sm" data-animation="fade-up">Check Availability</a>
                <a href="#overview" class="btn btn-accent animation-box anim-normal anim-delay-sm" data-animation="fade-up">Take a Tour</a>
            </div>
    </div>
  </div>
</section>

<%# === Section 3: Metrics Bar === %>
<section class="section metrics-section">
    <div class="hero-container">
        <div class="row row-cols-2 row-cols-md-4 g-4">
            <div class="col">
                <div class="metrics-card animation-box anim-normal anim-delay-sm" data-animation="fade-up">
                    <div class="metrics-icon">
                        <i class="fa-solid fa-tree"></i>
                    </div>
                    <div class="metrics-stat">
                        <span class="metrics-number counter" data-count="50">00</span>
                        <span class="metrics-suffix">+</span>
                    </div>
                    <span class="metrics-label">Retreats Hosted</span>
                </div>
            </div>
            <div class="col">
                <div class="metrics-card animation-box anim-normal anim-delay-sm" data-animation="fade-up">
                    <div class="metrics-icon">
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <div class="metrics-stat">
                        <span class="metrics-number counter" data-count="4.9">0.0</span>
                    </div>
                    <span class="metrics-label">Guest Rating</span>
                </div>
            </div>
            <div class="col">
                <div class="metrics-card animation-box anim-normal anim-delay-sm" data-animation="fade-up">
                    <div class="metrics-icon">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div class="metrics-stat">
                        <span class="metrics-number counter" data-count="4">00</span>
                    </div>
                    <span class="metrics-label">Max Guests</span>
                </div>
            </div>
            <div class="col">
                <div class="metrics-card animation-box anim-normal anim-delay-sm" data-animation="fade-up">
                    <div class="metrics-icon">
                        <i class="fa-solid fa-mountain"></i>
                    </div>
                    <div class="metrics-stat">
                        <span class="metrics-number counter" data-count="2022">0000</span>
                    </div>
                    <span class="metrics-label">Year Built</span>
                </div>
            </div>
        </div>
    </div>
</section>

<%# === Section 4: Property Overview === %>
<section id="overview" class="section">
    <div class="hero-container">
        <div class="d-flex flex-column flex-lg-row flex-gap-2 align-items-center">
            <div class="image-container col-lg-6">
                <%= image_tag "home/Untitled-1-900x600.jpg", alt: "The Anchorpoint Retreat exterior", class: "img-fluid" %>
            </div>
            <div class="col-lg-6">
                <span class="sub-heading animation-box anim-normal anim-delay-sm" data-animation="fade-up">The Property</span>
                <h2 class="animation-box anim-normal anim-delay-sm" data-animation="fade-up">Modern Alpine Retreat Near Breckenridge</h2>
                <p class="animation-box anim-normal anim-delay-sm" data-animation="fade-up">A private mountain chalet in Alma, Colorado, created for focused work, quiet resets, small leadership retreats, and year-round mountain adventure. Set near the base of Mosquito Pass, this contemporary 2022 chalet gives guests the space to step away from daily noise and reconnect with clear thinking, nature, and meaningful conversation.</p>
                <div class="property-specs d-flex flex-wrap flex-gap-2">
                    <div class="spec-item">
                        <span class="spec-value">1</span>
                        <span class="spec-label">Bedroom</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-value">1</span>
                        <span class="spec-label">Bathroom</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-value">4</span>
                        <span class="spec-label">Guests</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-value">1,080</span>
                        <span class="spec-label">Sq Ft</span>
                    </div>
                </div>
                <a href="/the-retreat#property-details" class="btn btn-accent mt-3" >Explore the Property</a>
            </div>
        </div>
    </div>
</section>

<%# === Section 5: Short Version Summary === %>
<section class="section">
    <div class="hero-container">
        <div class="card p-5 text-center" style="background: var(--bg-2); border: none;">
            <span class="sub-heading">At a Glance</span>
            <h2>A Private Alpine Basecamp for Focused Work and Colorado Mountain Adventure</h2>
            <p class="lead">Located near Mosquito Pass, about 5 minutes from Alma and about 30 minutes from Breckenridge, this modern 2022 chalet offers a quiet setting for small executive retreats, founder resets, remote-work stays, ski weekends, fishing trips, and outdoor escapes.</p>
            <p class="lead">Guests can enjoy modern comfort inside, peaceful mountain views outside, and easy access to skiing, hiking, fishing, scenic drives, wildlife viewing, and high-alpine exploring nearby.</p>
            <a href="/the-retreat" style="align-self: center;" class="btn btn-accent mt-2 d-inline-block">Explore the Retreat</a>
        </div>
    </div>
</section>

<%# === Section 6: Experience Types === %>
<section class="section-pb-small-px-large">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading animation-box anim-normal anim-delay-sm" data-animation="fade-up">Experiences</span>
        <h2 class="animation-box anim-normal anim-delay-sm" data-animation="fade-up">Perfect for Your Mountain Escape</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-1 row-cols-md-3 grid-gap-2">
            <div class="col">
                <div class="experience-card">
                    <div class="image-container">
                        <%= image_tag "home/cooperate-retreats-600-800.jpg", alt: "Founder Retreats", class: "img-fluid" %>
                        <div class="experience-overlay">
                            <p>&nbsp;</p>
                            <h3 class="experience-title">Founder Retreats &amp; Executive Resets</h3>
                            <p>Step away from the noise and think clearly. The quiet alpine setting, dedicated loft workspace, and mountain views create the ideal environment for focused strategy, planning, and recharged leadership.</p>
                          <p>&nbsp;</p>
                            <a href="/experience#founder" class="btn btn-accent-2">Learn More</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="experience-card">
                    <div class="image-container">
                        <%= image_tag "home/wellness-retreats-600-800.jpg", alt: "Remote Work Escapes", class: "img-fluid" %>
                        <div class="experience-overlay">
                            <p>&nbsp;</p>
                            <h3 class="experience-title">Remote Work &amp; Creative Escapes</h3>
                            <p>Trade your home office for mountain views. High-speed WiFi, a bright loft workspace, and peaceful surroundings let you stay productive while being steps away from hiking, skiing, and fresh air.</p>
                          <p>&nbsp;</p>
                            <a href="/experience#remote-work" class="btn btn-accent-2" >Learn More</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="experience-card">
                    <div class="image-container">
                        <%= image_tag "home/private-gatherning-600-800.jpg", alt: "Couples Getaways", class: "img-fluid" %>
                        <div class="experience-overlay">
                          <p>&nbsp;</p>
                          <h3 class="experience-title">Couples &amp; Small Group Getaways</h3>
                            <p>Perfect for a romantic escape or a small group adventure. With nearby skiing, fishing, hiking, and high-alpine exploring, it's the ideal base for shared experiences and quiet evenings by the fire.</p>
                          <p>&nbsp;</p>
                            <a href="/experience#couples" class="btn btn-accent-2">Learn More</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%# === Section 7: Photo Gallery === %>
<section class="section">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading animation-box anim-normal anim-delay-sm" data-animation="fade-up">Gallery</span>
        <h2 class="animation-box anim-normal anim-delay-sm" data-animation="fade-up">A Glimpse of Paradise</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-1 row-cols-md-3 g-3">
            <div class="col">
                <div class="image-container gallery-grid-item">
                    <%= image_tag "home/gallery/Image-3.jpg", alt: "Mountain view from property", class: "img-fluid" %>
                </div>
            </div>
            <div class="col">
                <div class="image-container gallery-grid-item">
                    <%= image_tag "home/gallery/Image-19.jpg", alt: "Great room interior", class: "img-fluid" %>
                </div>
            </div>
            <div class="col">
                <div class="image-container gallery-grid-item">
                    <%= image_tag "home/gallery/Image-17.jpg", alt: "Hot tub under stars", class: "img-fluid" %>
                </div>
            </div>
            <div class="col">
                <div class="image-container gallery-grid-item">
                    <%= image_tag "home/gallery/Image-13.jpg", alt: "Gourmet kitchen", class: "img-fluid" %>
                </div>
            </div>
            <div class="col">
                <div class="image-container gallery-grid-item">
                    <%= image_tag "home/gallery/Image-28.jpg", alt: "Trail view", class: "img-fluid" %>
                </div>
            </div>
            <div class="col">
                <div class="image-container gallery-grid-item">
                    <%= image_tag "home/gallery/Image-20.jpg", alt: "Sunset deck view", class: "img-fluid" %>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a href="/the-retreat#gallery" class="btn btn-accent">View All Photos</a>
        </div>
    </div>
</section>

<%# === Section 8: Amenities Grid === %>
<section class="section-px-pt-small">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading animation-box anim-normal anim-delay-sm" data-animation="fade-up">Amenities</span>
        <h2 class="animation-box anim-normal anim-delay-sm" data-animation="fade-up">Everything You Need</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-2 row-cols-md-4 grid-gap-2">
            <% amenities = [
                { icon: "fa-solid fa-tree", name: "Alpine Setting", desc: "Quiet valley near Mosquito Pass" },
                { icon: "fa-solid fa-mountain", name: "Mountain Views", desc: "Meadow & forest scenery with wildlife" },
                { icon: "fa-solid fa-person-hiking", name: "Outdoor Adventure", desc: "Hiking, skiing, fishing & more" },
                { icon: "fa-solid fa-wifi", name: "High-Speed WiFi", desc: "Stay connected when needed" },
                { icon: "fa-solid fa-kitchen-set", name: "Full Kitchen", desc: "Butcher block counters & SS appliances" },
                { icon: "fa-solid fa-couch", name: "Modern Comfort", desc: "16-ft ceilings & electric fireplace" },
                { icon: "fa-solid fa-bed", name: "1 Bed + Loft", desc: "Sleeps up to 4 guests" },
                { icon: "fa-solid fa-snowflake", name: "Ski Access", desc: "30 min to Breckenridge skiing" }
            ] %>
            <% amenities.each do |amenity| %>
                <div class="col">
                    <div class="card card-service animation-box anim-normal anim-delay-sm" data-animation="fade-up">
                        <div class="service-icon amenity-icon">
                            <i class="<%= amenity[:icon] %>"></i>
                        </div>
                        <div class="d-flex flex-column flex-gap-1">
                            <h3 class="heading-sm card-service-title"><%= amenity[:name] %></h3>
                            <p class="accent-color"><%= amenity[:desc] %></p>
                        </div>
                    </div>
                </div>
            <% end %>
        </div>
        <div class="text-center mt-4">
            <a href="/the-retreat#amenities" class="btn btn-accent">View All Amenities</a>
        </div>
    </div>
</section>

<%# === Section 9: How It Works === %>
<section class="section">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading animation-box anim-normal anim-delay-sm" data-animation="fade-up">Simple Process</span>
        <h2 class="animation-box anim-normal anim-delay-sm" data-animation="fade-up">How It Works</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-1 row-cols-md-3 grid-gap-3 steps-row">
            <div class="col text-center">
                <div class="step-icon">
                    <i class="fa-solid fa-calendar-check fa-3x accent-color"></i>
                </div>
                <h3 class="heading-sm mt-3">Choose Your Dates</h3>
                <p>Browse our availability calendar and select the perfect dates for your retreat.</p>
            </div>
            <div class="col text-center">
                <div class="step-icon">
                    <i class="fa-solid fa-users fa-3x accent-color"></i>
                </div>
                <h3 class="heading-sm mt-3">Tell Us About Your Group</h3>
                <p>Share details about your group size and retreat type so we can prepare for your arrival.</p>
            </div>
            <div class="col text-center">
                <div class="step-icon">
                    <i class="fa-solid fa-mountain fa-3x accent-color"></i>
                </div>
                <h3 class="heading-sm mt-3">Arrive and Unwind</h3>
                <p>Check in and let the mountains work their magic. Everything else is taken care of.</p>
            </div>
        </div>
        <div class="text-center mt-4">
            <a href="/availability" class="btn btn-accent">Check Availability</a>
        </div>
    </div>
</section>

<%# === Section 10: Testimonials === %>
<section class="section-pt-large-pb-large">
    <div class="hero-container">
        <div class="d-flex flex-column flex-gap-2">
            <span class="sub-heading">Testimonials</span>
            <h2 class="hidden">What Our Guests Say</h2>
            <div class="testimonial-box-container animation-box anim-normal anim-delay-sm" data-animation="fade-up">

                <div class="testimonial-box">
                    <p class="testimonial-quote">"The Anchorpoint Retreat exceeded every expectation. Our team left feeling refreshed, inspired, and closer than ever. The setting is absolutely magical."</p>
                    <div class="testimonial-star-container">
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                    </div>
                    <div class="d-flex flex-row align-items-center flex-gap-2">
                        <%= image_tag "dummy-img-600x600.jpg", alt: "Sarah M.", class: "testimonial-image" %>
                        <div class="d-flex flex-column flex-gap-0">
                            <h3 class="heading-sm testimonial-title">Sarah Mitchell</h3>
                            <p>CEO, TechVentures Inc.</p>
                        </div>
                    </div>
                </div>

                <div class="testimonial-box">
                    <p class="testimonial-quote">"A truly transformative experience. The wellness amenities, the quiet surroundings, and the attentive hosting made our yoga retreat unforgettable."</p>
                    <div class="testimonial-star-container">
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                    </div>
                    <div class="d-flex flex-row align-items-center flex-gap-2">
                        <%= image_tag "dummy-img-600x600.jpg", alt: "James R.", class: "testimonial-image" %>
                        <div class="d-flex flex-column flex-gap-0">
                            <h3 class="heading-sm testimonial-title">James Rodriguez</h3>
                            <p>Wellness Coach</p>
                        </div>
                    </div>
                </div>

                <div class="testimonial-box">
                    <p class="testimonial-quote">"We hosted our family reunion here and it was perfect. The large kitchen, the fire pit, the hiking trails — every detail was thoughtfully designed."</p>
                    <div class="testimonial-star-container">
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                        <i class="fa-solid fa-star testimonial-star"></i>
                    </div>
                    <div class="d-flex flex-row align-items-center flex-gap-2">
                        <%= image_tag "dummy-img-600x600.jpg", alt: "The Parkers", class: "testimonial-image" %>
                        <div class="d-flex flex-column flex-gap-0">
                            <h3 class="heading-sm testimonial-title">The Parker Family</h3>
                            <p>Annual Family Retreat</p>
                        </div>
                    </div>
                </div>

                <div class="testimonial-button-container">
                    <button class="testimonial-btn btn-prev">
                        <i class="fa-solid fa-arrow-left"></i>
                    </button>
                    <button class="testimonial-btn btn-next">
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<%# === Section 11: Nearby Activities Teaser === %>
<section class="section-px-pt-small">
    <div class="hero-container text-center mb-4">
        <span class="sub-heading animation-box anim-normal anim-delay-sm" data-animation="fade-up">Explore the Area</span>
        <h2 class="animation-box anim-normal anim-delay-sm" data-animation="fade-up">Things to Do Nearby</h2>
    </div>
    <div class="hero-container">
        <div class="row row-cols-2 row-cols-md-4 grid-gap-2">
            <div class="col">
                <div class="card card-service animation-box anim-normal anim-delay-sm text-center" data-animation="fade-up">
                    <div class="service-icon amenity-icon">
                        <i class="fa-solid fa-snowflake fa-2x accent-color"></i>
                    </div>
                    <h3 class="heading-sm card-service-title mt-2">Skiing &amp; Winter Sports</h3>
                    <p class="small">30 min to Breckenridge slopes</p>
                </div>
            </div>
            <div class="col">
                <div class="card card-service animation-box anim-normal anim-delay-sm text-center" data-animation="fade-up">
                    <div class="service-icon amenity-icon">
                        <i class="fa-solid fa-person-hiking fa-2x accent-color"></i>
                    </div>
                    <h3 class="heading-sm card-service-title mt-2">Hiking &amp; Scenic Drives</h3>
                    <p class="small">Mosquito Pass, Kite Lake &amp; more</p>
                </div>
            </div>
            <div class="col">
                <div class="card card-service animation-box anim-normal anim-delay-sm text-center" data-animation="fade-up">
                    <div class="service-icon amenity-icon">
                        <i class="fa-solid fa-fish fa-2x accent-color"></i>
                    </div>
                    <h3 class="heading-sm card-service-title mt-2">Fishing &amp; South Park</h3>
                    <p class="small">Trout fishing near Fairplay</p>
                </div>
            </div>
            <div class="col">
                <div class="card card-service animation-box anim-normal anim-delay-sm text-center" data-animation="fade-up">
                    <div class="service-icon amenity-icon">
                        <i class="fa-solid fa-store fa-2x accent-color"></i>
                    </div>
                    <h3 class="heading-sm card-service-title mt-2">Dining &amp; Shopping</h3>
                    <p class="small">Breckenridge town &amp; local gems</p>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a href="/the-retreat#nearby-activities" class="btn btn-accent">Explore All Activities</a>
        </div>
    </div>
</section>

<%# === Section 12: Availability CTA === %>
<section class="section cta-section" style="background-image: url('<%= asset_path('home/backg-1920-900.jpg') %>');">
    <div class="hero-container">
        <div class="cta-overlay text-center">
            <h2 class="cta-title">Ready to Plan Your Retreat?</h2>
            <p class="cta-text">Check real-time availability, explore pricing, and book your stay at The Anchorpoint Retreat.</p>
            <a href="/availability" class="btn btn-accent-2 btn-lg">View Availability</a>
        </div>
    </div>
</section>

<%# === Section 12: Footer — handled by shared/_footer.html.erb === %>
