<%# app/views/pages/privacy.html.erb %>
<% content_for :title, "Privacy Policy — The Anchorpoint Retreat" %>

<section class="section banner-home" style="background-image: url('/assets/dummy-img-1920x900.jpg'); min-height: 40vh;">
    <div class="hero-container">
        <div class="banner-home-container text-center">
            <h1 class="banner-home-title">Privacy Policy</h1>
            <p class="banner-home-excerpt">How We Handle Your Information</p>
        </div>
    </div>
</section>

<section class="section">
    <div class="hero-container">
        <h2>Information We Collect</h2>
        <p>We collect information you provide directly: name, email address, phone number, payment information (processed securely by Stripe), and any details you share through our inquiry or booking forms.</p>

        <h2 class="mt-4">How We Use Your Information</h2>
        <ul>
            <li>To process and manage your booking</li>
            <li>To communicate with you about your stay</li>
            <li>To send transactional emails (confirmations, reminders)</li>
            <li>To improve our services</li>
        </ul>

        <h2 class="mt-4">Data Protection</h2>
        <p>We implement industry-standard security measures. Payment processing is handled entirely by Stripe — we never store credit card details on our servers.</p>

        <h2 class="mt-4">Your Rights</h2>
        <p>You may request access to, correction of, or deletion of your personal data at any time by contacting us.</p>
    </div>
</section>
