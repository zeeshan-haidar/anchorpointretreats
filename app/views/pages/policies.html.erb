<%# app/views/pages/policies.html.erb %>
<% content_for :title, "Policies — The Anchorpoint Retreat" %>

<section class="section banner-home" style="background-image: url('/assets/dummy-img-1920x900.jpg'); min-height: 40vh;">
    <div class="hero-container">
        <div class="banner-home-container text-center">
            <h1 class="banner-home-title">Policies</h1>
            <p class="banner-home-excerpt">Cancellation Policy, House Rules & Terms of Stay</p>
        </div>
    </div>
</section>

<section class="section">
    <div class="hero-container">
        <h2>Cancellation Policy</h2>
        <ul>
            <li><strong>30+ days before check-in:</strong> Full refund (minus processing fees)</li>
            <li><strong>14-29 days before check-in:</strong> 50% refund</li>
            <li><strong>Less than 14 days:</strong> No refund</li>
            <li><strong>Early departure:</strong> No refund for unused nights</li>
        </ul>

        <h2 class="mt-4">House Rules</h2>
        <ul>
            <li>Check-in: 3:00 PM | Check-out: 11:00 AM</li>
            <li>Quiet hours: 10:00 PM - 8:00 AM</li>
            <li>Maximum occupancy: 16 guests</li>
            <li>No smoking inside the property</li>
            <li>Pets welcome with prior approval ($150 fee)</li>
            <li>Events must be pre-approved</li>
            <li>Please remove shoes in the entryway</li>
            <li>Use hot tub cover when not in use</li>
        </ul>

        <h2 class="mt-4">Terms of Stay</h2>
        <p>By booking The Anchorpoint Retreat, you agree to:</p>
        <ul>
            <li>Pay the full balance 30 days before check-in</li>
            <li>Provide a valid credit card for incidentals</li>
            <li>Report any damages promptly</li>
            <li>Follow all house rules and local regulations</li>
            <li>Release the host from liability for accidents or injuries</li>
        </ul>
    </div>
</section>
